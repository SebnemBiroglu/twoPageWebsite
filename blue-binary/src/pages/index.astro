
---
import Navbar from '../components/navbar.astro';
import books from '../data/books.json';
---
<html>
  <body>
    <Navbar />
	<header class="hero">
    <img src="/book.png" alt="New Arrivals Banner" class="banner-img" />
  </header>
    <main class="container">
      <div class="grid">
        {books.map(book => (
          <div class="card">
            <h3>{book.name}</h3>
            <p class="info">{book.info}</p>
            <p class="price">${book.price}</p>
            <a href={`/checkout?id=${book.id}`} class="cart-btn">Add to Cart</a>
          </div>
        ))}
      </div>
    </main>

    <style>
	.banner-img {
        width: 100%;
        height: 200px;    
        object-fit: cover; 
        display: block;
      }

      .container { 
		max-width: 900px; 
		margin: 40px auto; 
		padding: 0 20px; 
		font-family: sans-serif;
		}

      .grid { 
        display: grid; 
        grid-template-columns: repeat(3, 1fr);
        gap: 20px; 
      }

      .card { 
        border: 1px solid #eee; 
        padding: 15px; 
        border-radius: 10px; 
        text-align: center;
        background: #fafafa;
      }

      h3 {
		 margin: 0 0 10px 0; 
		 font-size: 1.1rem;
		 }
      .info {
		font-size: 0.85rem; 
		color: #666;
		min-height: 40px; 
		}

      .price { 
		font-weight: bold; 
		margin: 10px 0; 
		}

      .cart-btn { 
        display: block; 
        background: #595648; 
        color: #fff; 
        text-decoration: none; 
        padding: 8px; 
        border-radius: 5px;
        font-size: 0.9rem;
      }
    </style>
  </body>
</html>